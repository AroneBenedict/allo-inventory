# Neon (or Supabase) Postgres
# Get these from your Neon project dashboard → Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Random secret for protecting the cron endpoint
# Generate with: openssl rand -base64 32
CRON_SECRET="your-random-secret-here"
